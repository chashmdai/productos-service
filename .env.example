# productos-service (SMID 6.6) - variables de entorno de ejemplo
# Copiar a .env y ajustar. NUNCA versionar secretos reales.

# --- Servidor ---
SERVER_PORT=8092

# --- Base de datos (MySQL 8) ---
DB_URL=jdbc:mysql://localhost:3306/db_productos?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&tinyInt1isBit=true&characterEncoding=utf8
DB_USERNAME=smid
DB_PASSWORD=cambiar

# --- Seguridad JWT (HS256 con kid) ---
JWT_KID_ACTIVO=smid-2026-06
# Secreto activo: minimo 32 bytes (256 bits). REEMPLAZAR.
JWT_SECRET_ACTIVO=cambiar-por-un-secreto-de-al-menos-32-bytes
# Rotacion (opcional):
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=
JWT_ISSUER=smid-auth
JWT_AUDIENCIA=smid-servicios
ROLES_COORDINACION=COORDINACION,COORDINADOR

# --- Eventos ---
# transporte de publicacion: log | rabbitmq
EVENTOS_TRANSPORTE=log
# consumo de caso.abierto: none | rabbitmq
EVENTOS_CONSUMO=none

# --- Enriquecimiento (clientes REST) ---
ENRIQUECIMIENTO_CASOS=false
ENRIQUECIMIENTO_PERSONAS=false
CASOS_URL_BASE=http://localhost:8090/casos
PERSONAS_URL_BASE=http://localhost:8088/personas

# --- Sedes ---
SEDE_CODIGO_DEFECTO=STG

# --- RabbitMQ (si se usa) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HEALTH=false
